.weather{background:-webkit-linear-gradient(315deg,rgba(52,152,219,.15),rgba(46,204,113,.1));background:linear-gradient(135deg,rgba(52,152,219,.15),rgba(46,204,113,.1));border:1rpx solid rgba(52,152,219,.2);border-radius:24rpx;margin:20rpx 30rpx;padding:30rpx}.weather-error,.weather-loading{color:hsla(0,0%,100%,.4);display:block;font-size:26rpx;padding:20rpx 0;text-align:center}.weather-main{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;margin-bottom:16rpx}.weather-icon{font-size:72rpx;margin-right:20rpx}.weather-temp-wrap{-webkit-align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:start;align-items:flex-start}.weather-temp-wrap .weather-temp{color:#fff;font-size:80rpx;font-weight:700;line-height:1}.weather-temp-wrap .weather-unit{color:hsla(0,0%,100%,.5);font-size:28rpx;margin-left:4rpx;margin-top:10rpx}.weather-info{margin-bottom:20rpx}.weather-info .weather-desc{color:hsla(0,0%,100%,.8);display:block;font-size:30rpx;margin-bottom:6rpx}.weather-info .weather-city{color:hsla(0,0%,100%,.45);font-size:24rpx}.weather-detail{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-around;-ms-flex-pack:distribute;border-top:1rpx solid hsla(0,0%,100%,.08);justify-content:space-around;padding-top:20rpx}.weather-detail-item{text-align:center}.weather-detail-item .detail-label{color:hsla(0,0%,100%,.4);display:block;font-size:22rpx;margin-bottom:6rpx}.weather-detail-item .detail-value{color:hsla(0,0%,100%,.8);font-size:28rpx;font-weight:700}.calendar{background:hsla(0,0%,100%,.06);border:1rpx solid hsla(0,0%,100%,.08);border-radius:24rpx;margin:20rpx 30rpx;padding:24rpx}.calendar-nav{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;margin-bottom:24rpx}.nav-btn{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;height:64rpx;width:64rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;background:hsla(0,0%,100%,.06);border-radius:50%;justify-content:center}.nav-btn .nav-btn-text{color:hsla(0,0%,100%,.6);font-size:24rpx}.nav-title{-webkit-align-items:baseline;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:baseline;align-items:baseline;gap:8rpx}.nav-title .nav-year{color:hsla(0,0%,100%,.5);font-size:26rpx}.nav-title .nav-month{color:#fff;font-size:36rpx;font-weight:700}.calendar-weekdays{display:-webkit-flex;display:-ms-flexbox;display:flex;margin-bottom:12rpx}.weekday-cell{-webkit-flex:1;-ms-flex:1;flex:1;text-align:center}.weekday-cell .weekday-text{color:hsla(0,0%,100%,.4);font-size:22rpx;font-weight:700}.calendar-grid{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap}.day-cell{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;height:72rpx;width:14.2857142857%;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.day-cell .day-text{color:hsla(0,0%,100%,.8);font-size:28rpx}.day-cell--other .day-text{color:hsla(0,0%,100%,.2)}.day-cell--today .day-text{-webkit-align-items:center;background:#f0c040;border-radius:50%;color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:52rpx;width:52rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;color:#1a1a2e;font-weight:700;justify-content:center}.daily-page{background:-webkit-gradient(linear,left top,left bottom,from(#1a1a2e),color-stop(50%,#16213e),to(#0f3460));background:-webkit-linear-gradient(top,#1a1a2e,#16213e 50%,#0f3460);background:linear-gradient(180deg,#1a1a2e,#16213e 50%,#0f3460);min-height:100vh;padding-bottom:40rpx}.daily-header{padding:40rpx 30rpx 10rpx}.daily-header .daily-title{color:#fff;display:block;font-size:40rpx;font-weight:700;margin-bottom:8rpx}.daily-header .daily-date{color:hsla(0,0%,100%,.45);font-size:26rpx}