.index-page{background:-webkit-gradient(linear,left top,left bottom,from(#1a1a2e),color-stop(50%,#16213e),to(#0f3460));background:-webkit-linear-gradient(top,#1a1a2e,#16213e 50%,#0f3460);background:linear-gradient(180deg,#1a1a2e,#16213e 50%,#0f3460);min-height:100vh;padding:40rpx 40rpx 60rpx}.header{padding:60rpx 0 40rpx;text-align:center}.header .title{color:#f0c040;display:block;font-size:56rpx;font-weight:700;margin-bottom:12rpx}.header .subtitle{color:hsla(0,0%,100%,.5);font-size:26rpx}.section{background:hsla(0,0%,100%,.06);border:1rpx solid hsla(0,0%,100%,.08);border-radius:20rpx;margin-bottom:24rpx;padding:30rpx}.section-header{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;margin-bottom:10rpx}.section-header .section-icon{font-size:36rpx;margin-right:12rpx}.section-header .section-title{color:#fff;font-size:32rpx;font-weight:700}.section-desc{color:hsla(0,0%,100%,.45);display:block;font-size:24rpx;margin-bottom:20rpx}.btn-create{background:-webkit-linear-gradient(315deg,#f0c040,#e67e22);background:linear-gradient(135deg,#f0c040,#e67e22);border:none;border-radius:40rpx;color:#1a1a2e;font-size:30rpx;font-weight:700;height:80rpx;line-height:80rpx;width:100%}.btn-join{background:-webkit-linear-gradient(315deg,#3498db,#2980b9);background:linear-gradient(135deg,#3498db,#2980b9);border:none;border-radius:40rpx;color:#fff;font-size:30rpx;font-weight:700;height:80rpx;line-height:80rpx;width:100%}.btn-join[disabled]{opacity:.5}.room-code-input{background:hsla(0,0%,100%,.1);border-radius:40rpx;-webkit-box-sizing:border-box;box-sizing:border-box;color:#fff;font-size:32rpx;height:80rpx;letter-spacing:12rpx;margin-bottom:16rpx;padding:0 30rpx;text-align:center;width:100%}.input-placeholder{color:hsla(0,0%,100%,.3)}.divider{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;margin:10rpx 0 30rpx}.divider .divider-line{background:hsla(0,0%,100%,.15);-webkit-flex:1;-ms-flex:1;flex:1;height:1rpx}.divider .divider-text{color:hsla(0,0%,100%,.35);font-size:24rpx;margin:0 20rpx}.nickname-input{background:hsla(0,0%,100%,.1);border-radius:40rpx;-webkit-box-sizing:border-box;box-sizing:border-box;color:#fff;font-size:30rpx;height:80rpx;padding:0 30rpx;width:100%}.picker-row{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;background:hsla(0,0%,100%,.08);border-radius:12rpx;justify-content:space-between;margin-bottom:20rpx;padding:16rpx 20rpx}.picker-row .picker-label{color:hsla(0,0%,100%,.7);font-size:26rpx}.picker-row .picker-value{background:rgba(240,192,64,.15);border-radius:20rpx;color:#f0c040;font-size:28rpx;font-weight:700;padding:6rpx 20rpx}.my-room-section{background:rgba(240,192,64,.08);border:2rpx solid rgba(240,192,64,.4);position:relative}.my-room-section .return-arrow{color:#f0c040;font-size:32rpx;margin-left:auto}.recent-room-section{background:rgba(52,152,219,.08);border:2rpx solid rgba(52,152,219,.4);position:relative}.recent-hint{color:rgba(52,152,219,.6);display:block;font-size:22rpx;margin-top:4rpx}.user-info{padding:20rpx 0;text-align:center}.user-info .user-label{color:hsla(0,0%,100%,.35);font-size:22rpx;margin-right:8rpx}.user-info .user-value{color:hsla(0,0%,100%,.5);font-family:monospace;font-size:22rpx}