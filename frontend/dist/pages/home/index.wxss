.home-page{background:-webkit-gradient(linear,left top,left bottom,from(#1a1a2e),color-stop(50%,#16213e),to(#0f3460));background:-webkit-linear-gradient(top,#1a1a2e,#16213e 50%,#0f3460);background:linear-gradient(180deg,#1a1a2e,#16213e 50%,#0f3460);min-height:100vh;padding:0 40rpx 60rpx}.home-header{padding:80rpx 0 50rpx;text-align:center}.home-header .home-logo{display:block;font-size:80rpx;margin-bottom:20rpx}.home-header .home-title{color:#f0c040;display:block;font-size:48rpx;font-weight:700;margin-bottom:12rpx}.home-header .home-subtitle{color:hsla(0,0%,100%,.45);font-size:26rpx}.module-section{margin-bottom:40rpx}.module-section-header{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;margin-bottom:24rpx}.module-section-header .module-section-icon{font-size:32rpx;margin-right:10rpx}.module-section-header .module-section-title{color:hsla(0,0%,100%,.85);font-size:30rpx;font-weight:700}.module-grid{display:grid;gap:20rpx;grid-template-columns:1fr 1fr}.module-card{background:hsla(0,0%,100%,.06);border:1rpx solid hsla(0,0%,100%,.1);border-radius:24rpx;-webkit-box-sizing:border-box;box-sizing:border-box;overflow:hidden;padding:30rpx 24rpx;position:relative;-webkit-transition:all .2s ease;transition:all .2s ease;width:100%}.module-card:active{background:hsla(0,0%,100%,.1);-webkit-transform:scale(.97);-ms-transform:scale(.97);transform:scale(.97)}.module-card--disabled{opacity:.5}.module-card--disabled:active{-webkit-transform:none;-ms-transform:none;transform:none}.module-card-icon{-webkit-align-items:center;border-radius:20rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;height:80rpx;width:80rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;margin-bottom:16rpx}.module-card-icon .module-card-emoji{font-size:42rpx}.module-card-title{color:#fff;display:block;font-size:30rpx;font-weight:700;margin-bottom:8rpx}.module-card-desc{color:hsla(0,0%,100%,.4);display:block;font-size:22rpx;line-height:1.4}.module-card-badge{background:hsla(184,9%,62%,.3);border-radius:12rpx;padding:4rpx 12rpx;position:absolute;right:16rpx;top:16rpx}.module-card-badge .module-card-badge-text{color:hsla(0,0%,100%,.5);font-size:18rpx}.home-footer{padding:40rpx 0 20rpx;text-align:center}.home-footer .home-footer-text{color:hsla(0,0%,100%,.25);font-family:monospace;font-size:22rpx}