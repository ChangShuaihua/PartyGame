.companion-page{background:-webkit-gradient(linear,left top,left bottom,from(#1a1a2e),color-stop(50%,#16213e),to(#0f3460));background:-webkit-linear-gradient(top,#1a1a2e,#16213e 50%,#0f3460);background:linear-gradient(180deg,#1a1a2e,#16213e 50%,#0f3460);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh;padding-bottom:140rpx}.character-area{background:hsla(0,0%,100%,.03);border-bottom:1rpx solid hsla(0,0%,100%,.06);padding:40rpx 0 20rpx;text-align:center}.character-avatar{-webkit-align-items:center;background:-webkit-linear-gradient(315deg,#f0c040,#e67e22);background:linear-gradient(135deg,#f0c040,#e67e22);border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:120rpx;width:120rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;-webkit-box-shadow:0 8rpx 30rpx rgba(240,192,64,.3);box-shadow:0 8rpx 30rpx rgba(240,192,64,.3);justify-content:center;margin:0 auto 12rpx}.character-avatar .character-face{font-size:56rpx}.character-name{color:#f0c040;display:block;font-size:30rpx;font-weight:700;margin-bottom:4rpx}.character-desc{color:hsla(0,0%,100%,.4);font-size:22rpx}.chat-area{-webkit-flex:1;-ms-flex:1;flex:1;padding:20rpx 24rpx}.chat-bubble-wrap{-webkit-align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:start;align-items:flex-start;margin-bottom:20rpx}.chat-bubble-wrap--user{-webkit-flex-direction:row-reverse;-ms-flex-direction:row-reverse;flex-direction:row-reverse}.bubble-avatar{-webkit-align-items:center;background:rgba(240,192,64,.2);border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:60rpx;width:60rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;-webkit-flex-shrink:0;justify-content:center;margin-right:12rpx;-ms-flex-negative:0;flex-shrink:0}.bubble-avatar .bubble-avatar-text{font-size:32rpx}.chat-bubble-wrap--user .bubble-avatar{margin-left:12rpx;margin-right:0}.chat-bubble{border-radius:24rpx;max-width:70%;padding:20rpx 24rpx;position:relative}.chat-bubble--bot{background:hsla(0,0%,100%,.1);border:1rpx solid hsla(0,0%,100%,.08);border-top-left-radius:8rpx}.chat-bubble--user{background:-webkit-linear-gradient(315deg,#f0c040,#e67e22);background:linear-gradient(135deg,#f0c040,#e67e22);border-top-right-radius:8rpx}.bubble-text{color:#fff;display:block;font-size:28rpx;line-height:1.6;word-break:break-all}.chat-bubble--user .bubble-text{color:#1a1a2e}.bubble-time{color:hsla(0,0%,100%,.3);display:block;font-size:18rpx;margin-top:8rpx;text-align:right}.chat-bubble--user .bubble-time{color:rgba(26,26,46,.4)}.typing-dots{-webkit-animation:pulse 1.5s infinite;animation:pulse 1.5s infinite}@-webkit-keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}@keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}.input-area{-webkit-align-items:center;bottom:0;display:-webkit-flex;display:-ms-flexbox;display:flex;left:0;position:fixed;right:0;-ms-flex-align:center;align-items:center;-webkit-backdrop-filter:blur(20rpx);backdrop-filter:blur(20rpx);background:rgba(26,26,46,.95);border-top:1rpx solid hsla(0,0%,100%,.08);gap:16rpx;padding:16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom))}.chat-input{background:hsla(0,0%,100%,.1);border-radius:36rpx;-webkit-box-sizing:border-box;box-sizing:border-box;color:#fff;-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx;height:72rpx;padding:0 24rpx}.input-placeholder{color:hsla(0,0%,100%,.3)}.btn-send{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;height:72rpx;width:120rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;background:-webkit-linear-gradient(315deg,#f0c040,#e67e22);background:linear-gradient(135deg,#f0c040,#e67e22);border-radius:36rpx;-webkit-flex-shrink:0;justify-content:center;-ms-flex-negative:0;flex-shrink:0}.btn-send .btn-send-text{color:#1a1a2e;font-size:28rpx;font-weight:700}.btn-send--disabled{opacity:.4}